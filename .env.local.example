# Google Maps JavaScript API キー
# https://console.cloud.google.com/ で取得してください
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSyDymVI_NxJtFshb7R1y-15npGAHATGEtlc

# Google Maps Map ID (AdvancedMarker に必要)
# Google Maps Platform > マップのスタイル > 新しいマップ ID を作成
# 開発時は "DEMO_MAP_ID" が利用可能（一部機能制限あり）
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=DEMO_MAP_ID

# ピンデータの CSV URL（省略時は /pins.csv を使用）
# Google スプレッドシートの場合:
#   NEXT_PUBLIC_CSV_URL=https://docs.google.com/spreadsheets/d/<SHEET_ID>/export?format=csv
NEXT_PUBLIC_CSV_URL=/pins.csv
